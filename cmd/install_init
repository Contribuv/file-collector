#!/bin/bash
### 安装前初始化回调
### 区分首次安装和升级场景：
###   - 首次安装：数据库不存在，需要 wizard 收集管理员账号
###   - 升级安装：数据库已存在，保留所有数据，跳过账号设置

# 数据目录（与 main 脚本保持一致：优先 TRIM_DATA_SHARE_PATHS）
if [ -n "$TRIM_DATA_SHARE_PATHS" ]; then
    _SHARE_BASE="${TRIM_DATA_SHARE_PATHS%%:*}"
    DATA_DIR="${_SHARE_BASE}/data"
elif [ -n "$TRIM_PKGVAR" ]; then
    DATA_DIR="${TRIM_PKGVAR}/data"
else
    DATA_DIR="/tmp/file-collector/data"
fi
mkdir -p "$DATA_DIR"
LOG="${DATA_DIR}/install.log"
echo "[$(date)] === INSTALL INIT ===" >> "$LOG"

DB_PATH="${DATA_DIR}/file_collector.db"

if [ -f "$DB_PATH" ]; then
    DB_SIZE=$(stat -c%s "$DB_PATH" 2>/dev/null || echo "0")
    echo "  检测到已有数据库 (${DB_SIZE} bytes)，判定为升级安装" >> "$LOG"
    echo "  数据将保留，不会覆盖" >> "$LOG"
else
    echo "  数据库不存在，判定为首次安装" >> "$LOG"
    echo "  将通过安装向导设置管理员账号" >> "$LOG"
fi

echo "[$(date)] install_init done" >> "$LOG"
exit 0
