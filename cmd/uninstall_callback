#!/bin/bash
### 卸载后回调 - 清理应用文件，根据卸载向导选择处理数据库

APP_NAME="file-collector"
LOG="/tmp/${APP_NAME}-uninstall-callback.log"

echo "[$(date)] === UNINSTALL CALLBACK ===" >> "$LOG"

clean_dir() {
    local dir="$1"
    if [ -d "$dir" ]; then
        rm -rf "$dir"
        echo "  已删除: $dir" >> "$LOG"
    fi
}

# ============================================================
# 读取卸载向导选择
# ============================================================
UNINSTALL_MODE="${wizard_uninstall_mode:-keep_db}"
echo "  卸载模式: ${UNINSTALL_MODE}" >> "$LOG"

# ============================================================
# 上传文件始终保留（用户资料，禁止删除）
# ============================================================
echo "  上传文件始终保留（禁止删除）" >> "$LOG"

# ============================================================
# 处理数据库
# ============================================================
if [ "$UNINSTALL_MODE" = "delete_db" ]; then
    echo "  用户选择：删除数据库" >> "$LOG"

    # 删除 TRIM_PKGVAR 中的数据库（main 脚本可能已删除，再次确保）
    if [ -f "${TRIM_PKGVAR}/data/file_collector.db" ]; then
        rm -f "${TRIM_PKGVAR}/data/file_collector.db"
        rm -f "${TRIM_PKGVAR}/data/file_collector.db-wal" 2>/dev/null || true
        rm -f "${TRIM_PKGVAR}/data/file_collector.db-shm" 2>/dev/null || true
        echo "  已删除数据库及 WAL 文件" >> "$LOG"
    fi

    # 清理 PKGVAR 内备份（数据库已删除，备份无意义）
    if [ -d "${TRIM_PKGVAR}/backups" ]; then
        rm -rf "${TRIM_PKGVAR}/backups"
        echo "  已清理 PKGVAR 内备份" >> "$LOG"
    fi

    # 清理 /var/backups 中的备份（用户明确要删除）
    SAFE_BACKUP_DIR="/var/backups/file-collector"
    if [ -d "$SAFE_BACKUP_DIR" ]; then
        rm -rf "$SAFE_BACKUP_DIR"
        echo "  已清理 /var/backups 备份" >> "$LOG"
    fi
else
    echo "  用户选择：保留数据库" >> "$LOG"

    # 保留模式：安全备份数据库到 /var/backups（PKGVAR 可能被 fnOS 清理）
    if [ -n "$TRIM_PKGVAR" ] && [ -f "${TRIM_PKGVAR}/data/file_collector.db" ]; then
        SAFE_BACKUP_DIR="/var/backups/file-collector"
        mkdir -p "$SAFE_BACKUP_DIR"
        cp "${TRIM_PKGVAR}/data/file_collector.db" "${SAFE_BACKUP_DIR}/file_collector_$(date +%Y%m%d_%H%M%S).db"
        echo "  已安全备份数据库到: ${SAFE_BACKUP_DIR}" >> "$LOG"
        ls -t "${SAFE_BACKUP_DIR}"/file_collector_*.db 2>/dev/null | tail -n +6 | xargs rm -f 2>/dev/null
    fi
fi

# 只清理 venv 和运行时文件
if [ -n "$TRIM_PKGVAR" ] && [ -d "$TRIM_PKGVAR" ]; then
    rm -rf "${TRIM_PKGVAR}/.venv" 2>/dev/null || true
    rm -f "${TRIM_PKGVAR}/gunicorn.pid" "${TRIM_PKGVAR}/gunicorn.log" 2>/dev/null || true
    rm -f "${TRIM_PKGVAR}/.write_test" 2>/dev/null || true
    rm -f "${TRIM_PKGVAR}/.venv_cache.tar.gz" 2>/dev/null || true
    echo "  已清理 TRIM_PKGVAR 运行时文件" >> "$LOG"
fi

# 清理 /var/apps 下的应用残留（不涉及用户数据）
for dir in /var/apps/file-collector /var/apps/file-collector-*; do
    clean_dir "$dir"
done 2>/dev/null || true

# 清理 /usr/local/apps 残留
for dir in /usr/local/apps/@appcenter/file-collector /usr/local/apps/file-collector; do
    clean_dir "$dir"
done 2>/dev/null || true

# 清理 /tmp 残留
rm -rf /tmp/file-collector /tmp/file-collector-* 2>/dev/null || true

if [ "$UNINSTALL_MODE" = "delete_db" ]; then
    echo "[$(date)] callback done (数据库已删除，上传文件已保留)" >> "$LOG"
else
    echo "[$(date)] callback done (数据库已保留，上传文件已保留)" >> "$LOG"
fi
exit 0
